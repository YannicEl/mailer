{
	"name": "@mailer/frontend",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"cf-typegen": "wrangler types --env preview && move worker-configuration.d.ts src/",
		"deploy:dev": "pnpm build && wrangler pages deploy --branch dev --commit-dirty=true",
		"deploy:prod": "pnpm build && wrangler pages deploy --branch main --commit-dirty=true",
		"test:integration": "playwright test",
		"test:unit": "vitest run",
		"test": "pnpm test:unit && pnpm test:integration",
    "prepare": "svelte-kit sync"
	},
	"devDependencies": {
		"@playwright/test": "1.51.1",
		"@sveltejs/adapter-cloudflare": "4.9.0",
		"@sveltejs/kit": "2.20.5",
		"@sveltejs/vite-plugin-svelte": "4.0.4",
		"sass-embedded": "1.86.3",
		"svelte": "5.25.12",
		"svelte-check": "4.1.5",
		"tslib": "2.8.1",
		"typescript": "5.8.3",
		"unocss": "0.65.4",
		"vite": "5.4.18",
		"vitest": "2.1.9",
		"wrangler": "3.114.5"
	},
	"dependencies": {
		"@lucia-auth/adapter-drizzle": "1.1.0",
		"@mailer/db": "workspace:",
		"@mailer/lib": "workspace:",
		"@unocss/reset": "0.65.4",
		"drizzle-orm": "0.41.0",
		"lucia": "3.2.2",
		"oslo": "1.2.1",
		"zod": "3.24.2"
	}
}
